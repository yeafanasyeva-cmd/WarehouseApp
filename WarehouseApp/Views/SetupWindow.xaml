<Window x:Class="WarehouseApp.Views.SetupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Настройка подключения к базе данных" Height="500" Width="500"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Настройка подключения к базе данных" 
                   FontSize="16" FontWeight="Bold" Margin="0,0,0,15" HorizontalAlignment="Center"/>

        <TextBlock Grid.Row="1" Text="Сервер (Host):" Margin="0,5"/>
        <TextBox x:Name="txtHost" Grid.Row="2" Margin="0,5" Height="30" Text="localhost"/>

        <TextBlock Grid.Row="3" Text="Порт:" Margin="0,5"/>
        <TextBox x:Name="txtPort" Grid.Row="4" Margin="0,5" Height="30" Text="5432"/>

        <TextBlock Grid.Row="5" Text="Имя базы данных:" Margin="0,5"/>
        <TextBox x:Name="txtDatabase" Grid.Row="6" Margin="0,5" Height="30" Text="WarehouseApp"/>

        <TextBlock Grid.Row="7" Text="Пользователь:" Margin="0,5"/>
        <TextBox x:Name="txtUsername" Grid.Row="8" Margin="0,5" Height="30" Text="postgres"/>

        <TextBlock Grid.Row="9" Text="Пароль:" Margin="0,5"/>
        <PasswordBox x:Name="txtPassword" Grid.Row="10" Margin="0,5" Height="30"/>

        <TextBlock x:Name="lblStatus" Grid.Row="11" Text="" Margin="0,10" 
                   Foreground="Red" TextWrapping="Wrap" TextAlignment="Center"/>

        <StackPanel Grid.Row="12" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10">
            <Button x:Name="btnTest" Content="Проверить подключение" 
                    Width="150" Height="35" Margin="5"/>
            <Button x:Name="btnSave" Content="Подключиться" 
                    Width="150" Height="35" Margin="5" IsEnabled="False"/>
            <Button x:Name="btnExit" Content="Выход" 
                    Width="100" Height="35" Margin="5"/>
        </StackPanel>
    </Grid>
</Window>