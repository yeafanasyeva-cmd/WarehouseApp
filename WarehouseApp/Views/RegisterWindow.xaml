<Window x:Class="WarehouseApp.Views.RegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Регистрация нового пользователя" Height="500" Width="450"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="322.88"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Регистрация нового пользователя" 
                   FontSize="18" FontWeight="Bold" Margin="0,0,0,20" HorizontalAlignment="Center"/>

        <TextBlock Grid.Row="1" Text="Логин:" Margin="0,5,0,5"/>
        <TextBox x:Name="txtLogin" Grid.Row="2" Margin="0,5,0,288" Height="30"/>

        <TextBlock Grid.Row="2" Text="Пароль:" Margin="0,45,0,262"/>
        <PasswordBox x:Name="txtPassword" Grid.Row="2" Margin="0,71,0,222" Height="30"/>

        <TextBlock Grid.Row="2" Text="Подтверждение пароля:" Margin="0,111,0,196"/>
        <PasswordBox x:Name="txtConfirmPassword" Grid.Row="2" Margin="0,137,0,156" Height="30"/>

        <TextBlock Grid.Row="2" Text="ФИО:" Margin="0,177,0,130"/>
        <TextBox x:Name="txtFullName" Grid.Row="2" Margin="0,203,0,90" Height="30"/>

        <TextBlock Grid.Row="2" Text="Компания (необязательно):" Margin="0,243,0,5"/>
        <TextBox x:Name="txtCompany" Grid.Row="2" Margin="0,265,0,28" Height="30"/>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,312,0,-34">
            <Button x:Name="btnRegister" Content="Зарегистрироваться" Width="140" Height="35" Margin="5" 
                    Click="BtnRegister_Click" Background="LightGreen"/>
            <Button x:Name="btnCancel" Content="Отмена" Width="100" Height="35" Margin="5" 
                    Click="BtnCancel_Click" Background="LightCoral"/>
        </StackPanel>
    </Grid>
</Window>