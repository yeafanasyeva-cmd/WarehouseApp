<Window x:Class="WarehouseApp.Views.UserMainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Пользователь - Складские помещения" Height="600" Width="850"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Добро пожаловать!" 
                   FontSize="16" FontWeight="Bold" Margin="0,0,0,10" HorizontalAlignment="Center"/>

        <TabControl Grid.Row="1" Margin="0,10">
            <TabItem Header="Доступные помещения">
                <DataGrid x:Name="dgWarehouses" AutoGenerateColumns="False" 
                          SelectionMode="Single" SelectionUnit="FullRow"
                          Margin="5" Height="350">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Название" Binding="{Binding Name}" Width="150"/>
                        <DataGridTextColumn Header="Адрес" Binding="{Binding Address}" Width="250"/>
                        <DataGridTextColumn Header="Особые условия" Binding="{Binding SpecialConditions}" Width="250"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

            <TabItem Header="Мои заявки">
                <DataGrid x:Name="dgMyRequests" AutoGenerateColumns="False" 
                          SelectionMode="Single" SelectionUnit="FullRow"
                          Margin="5" Height="350">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Помещение" Binding="{Binding WarehouseName}" Width="150"/>
                        <DataGridTextColumn Header="Статус" Binding="{Binding Status}" Width="100"/>
                        <DataGridTextColumn Header="Особые условия" Binding="{Binding SpecialConditions}" Width="200"/>
                        <DataGridTextColumn Header="Дата заявки" Binding="{Binding RequestDate, StringFormat=\{0:dd.MM.yyyy HH:mm\}}" Width="130"/>
                        <DataGridTextColumn Header="Кто одобрил" Binding="{Binding ApprovedByName}" Width="120"/>
                        <DataGridTextColumn Header="Дата одобрения" Binding="{Binding ApprovedDate, StringFormat=\{0:dd.MM.yyyy HH:mm\}}" Width="130"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
        </TabControl>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="5,10" HorizontalAlignment="Center">
            <Button x:Name="btnCreateRequest" Content="Создать заявку на аренду" Width="180" Height="35" Margin="5" 
                    Click="BtnCreateRequest_Click" Background="LightGreen"/>
            <Button x:Name="btnDetails" Content="Подробнее о помещении" Width="150" Height="35" Margin="5" Click="BtnDetails_Click"/>
            <Button x:Name="btnRefresh" Content="Обновить список заявок" Width="150" Height="35" Margin="5" 
                    Click="BtnRefresh_Click" Background="LightBlue"/>
        </StackPanel>

        <StatusBar Grid.Row="3" Margin="0,10,0,0">
            <StatusBarItem>
                <TextBlock x:Name="lblStatus"/>
            </StatusBarItem>
        </StatusBar>

        <Button x:Name="btnExit" Content="Выход" Width="100" Height="35" 
                HorizontalAlignment="Right" VerticalAlignment="Bottom" 
                Margin="0,0,10,10" Click="BtnExit_Click" Background="LightCoral"/>
    </Grid>
</Window>
