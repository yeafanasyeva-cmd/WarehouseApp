<Window x:Class="WarehouseApp.Views.VisitManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Менеджер посещений" Height="500" Width="900"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Менеджер посещений" 
                   FontSize="16" FontWeight="Bold" Margin="0,0,0,10" HorizontalAlignment="Center"/>

        <DataGrid x:Name="dgVisits" Grid.Row="1" AutoGenerateColumns="False" 
                  SelectionMode="Single" SelectionUnit="FullRow"
                  Margin="5">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Склад" Binding="{Binding WarehouseName}" Width="120"/>
                <DataGridTextColumn Header="Арендатор" Binding="{Binding UserName}" Width="120"/>
                <DataGridTextColumn Header="Имя" Binding="{Binding FirstName}" Width="100"/>
                <DataGridTextColumn Header="Фамилия" Binding="{Binding LastName}" Width="100"/>
                <DataGridTextColumn Header="Компания" Binding="{Binding Company}" Width="120"/>
                <DataGridTextColumn Header="Номер машины" Binding="{Binding CarNumber}" Width="100"/>
                <DataGridTextColumn Header="Дата и время" Binding="{Binding VisitDate}" Width="150"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="5,10" HorizontalAlignment="Center">
            <Button x:Name="btnAdd" Content="Добавить посещение" Width="150" Height="35" Margin="5" Click="BtnAdd_Click"/>
            <Button x:Name="btnDelete" Content="Удалить" Width="100" Height="35" Margin="5" Click="BtnDelete_Click"/>
            <Button x:Name="btnClose" Content="Закрыть" Width="100" Height="35" Margin="5" Click="BtnClose_Click"/>
        </StackPanel>

        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="5,10">
            <TextBlock Text="Активная аренда:" VerticalAlignment="Center"/>
            <ComboBox x:Name="cmbRents" Width="300" Margin="5,0" 
                      DisplayMemberPath="WarehouseName" SelectedValuePath="Id"/>
        </StackPanel>
    </Grid>
</Window>